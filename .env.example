# API local
API_PORT=3001

# Supabase
# Crea un proyecto en Supabase y copia estos valores desde Project Settings > API.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Bucket privado donde se guardarán perfiles, JSONs e imágenes.
SUPABASE_BUCKET=gym22

# En nube usa /tmp para no depender de disco persistente.
RUNTIME_DATA_DIR=/tmp/gym22-usuarios
